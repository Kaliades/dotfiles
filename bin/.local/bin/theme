#!/usr/bin/env bash
# theme — lokalny przełącznik motywu Ghostty + nvim, BEZ ruszania trybu jasny/ciemny macOS.
#
# Stan (per-urządzenie, POZA dotfiles/gitem):
#   ~/.config/theme-mode           → nazwa colorscheme dla nvim (gruvbox / gruvbox-light / catppuccin-mocha)
#   ~/.config/ghostty-theme.local  → 'theme = ...' include'owane opcjonalnie przez config Ghostty
#   ~/.cache/zellij-active.kdl     → wygenerowany config Zellija (ZELLIJ_CONFIG_FILE z .zshrc)
#
# Użycie: theme [day|night|light|toggle|status]   (bez argumentu = toggle)
#   day   → Gruvbox Dark Hard   (jasne otoczenie, wysoki kontrast)
#   night → Catppuccin Mocha    (miększy, po ciemku)
#   light → Gruvbox Light Hard  (pełne słońce — jasne tło)
# toggle przełącza day ⇄ night (codzienna para); light jest zawsze jawny,
# a toggle z lighta wraca do day.
set -euo pipefail

STATE="$HOME/.config/theme-mode"
GHOSTTY_LOCAL="$HOME/.config/ghostty-theme.local"
STARSHIP_TEMPLATE="$HOME/.config/starship.toml"
STARSHIP_ACTIVE="${XDG_CACHE_HOME:-$HOME/.cache}/starship-active.toml"
BAT_LOCAL="$HOME/.config/theme-bat"  # czytany przez .zshrc → BAT_THEME (i delta dziedziczy)
ZELLIJ_TEMPLATE="$HOME/.config/zellij/config.kdl"
ZELLIJ_ACTIVE="${XDG_CACHE_HOME:-$HOME/.cache}/zellij-active.kdl"

nvim_day="gruvbox";            ghostty_day="Gruvbox Dark Hard";    starship_day="gruvbox_dark";       bat_day="gruvbox-dark";      zellij_day="gruvbox-dark"
nvim_night="catppuccin-mocha"; ghostty_night="Catppuccin Mocha";   starship_night="catppuccin_mocha"; bat_night="Catppuccin Mocha"; zellij_night="catppuccin-mocha"
nvim_light="gruvbox-light";    ghostty_light="Gruvbox Light Hard"; starship_light="gruvbox_light";    bat_light="gruvbox-light";   zellij_light="gruvbox-light"

current_scheme="$(cat "$STATE" 2>/dev/null || echo "$nvim_night")"
case "$current_scheme" in
  "$nvim_day")   current=day ;;
  "$nvim_light") current=light ;;
  *)             current=night ;;
esac

case "${1:-toggle}" in
  day|gruvbox)            mode=day ;;
  night|catppuccin|mocha) mode=night ;;
  light|jasny|sun)        mode=light ;;
  toggle|"")
    if [ "$current" = night ]; then mode=day; else mode=night; fi
    [ "$current" = light ] && mode=day ;;
  status)
    echo "tryb:     $current"
    echo "nvim:     $current_scheme"
    echo "ghostty:  $(cat "$GHOSTTY_LOCAL" 2>/dev/null || echo '(default z config)')"
    echo "starship: $(grep -m1 '^palette' "$STARSHIP_ACTIVE" 2>/dev/null || echo '(default z szablonu)')"
    echo "zellij:   $(grep -m1 '^theme ' "$ZELLIJ_ACTIVE" 2>/dev/null || echo '(default z szablonu)')"
    echo "bat/delta: $(cat "$BAT_LOCAL" 2>/dev/null || echo '(default)')"
    exit 0 ;;
  *) echo "użycie: theme [day|night|light|toggle|status]" >&2; exit 1 ;;
esac

case "$mode" in
  day)   nvim_scheme="$nvim_day";   ghostty_theme="$ghostty_day";   starship_palette="$starship_day";   bat_theme="$bat_day";   zellij_theme="$zellij_day" ;;
  night) nvim_scheme="$nvim_night"; ghostty_theme="$ghostty_night"; starship_palette="$starship_night"; bat_theme="$bat_night"; zellij_theme="$zellij_night" ;;
  light) nvim_scheme="$nvim_light"; ghostty_theme="$ghostty_light"; starship_palette="$starship_light"; bat_theme="$bat_light"; zellij_theme="$zellij_light" ;;
esac

printf '%s\n' "$nvim_scheme" > "$STATE"
printf 'theme = %s\n' "$ghostty_theme" > "$GHOSTTY_LOCAL"
printf '%s\n' "$bat_theme" > "$BAT_LOCAL"

# Starship — regeneruj aktywny config z szablonu, podmieniając tylko paletę.
# starship czyta plik co prompt → wszystkie otwarte shelle przeskakują przy następnym Enterze.
if [ -f "$STARSHIP_TEMPLATE" ]; then
  mkdir -p "$(dirname "$STARSHIP_ACTIVE")"
  sed "s/^palette = .*/palette = '$starship_palette'/" "$STARSHIP_TEMPLATE" > "$STARSHIP_ACTIVE"
fi

# Zellij — regeneruj aktywny config z szablonu, podmieniając tylko linię `theme "..."`.
# Zellij obserwuje swój plik configu (ZELLIJ_CONFIG_FILE z .zshrc → ten cache),
# więc WSZYSTKIE żywe sesje przemalowują się same, bez zellij action.
# Bez slotów theme_dark/theme_light — patrz komentarz w szablonie (auto-switch
# po jasności hosta psuł attach po SSH).
if [ -f "$ZELLIJ_TEMPLATE" ]; then
  mkdir -p "$(dirname "$ZELLIJ_ACTIVE")"
  sed "s/^theme .*/theme \"$zellij_theme\"/" "$ZELLIJ_TEMPLATE" > "$ZELLIJ_ACTIVE"
fi

# Przeładuj Ghostty (reload_config). Brak CLI do zdalnego sterowania → wysyłamy keystroke
# Cmd+Shift+, do aktywnej apki. Wymaga RAZ uprawnień Accessibility dla terminala.
if command -v osascript >/dev/null 2>&1; then
  osascript -e 'tell application "System Events" to keystroke "," using {command down, shift down}' >/dev/null 2>&1 \
    || echo "→ naciśnij Cmd+Shift+, w Ghostty, by przeładować motyw terminala"
fi

echo "✓ motyw: $mode  (nvim ≤2 s; zellij/starship od razu; bat/delta w nowych shellach)"
