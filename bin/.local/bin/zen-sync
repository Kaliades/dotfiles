#!/usr/bin/env bash
# zen-sync — synchronizacja configu Zen Browser między maszynami (Mac Mini ⇄ MacBook) przez iCloud.
#
# Po co to jest:
#   Wbudowany Firefox/Mozilla Sync w Zen synchronizuje zakładki, hasła, historię, otwarte
#   karty i LISTĘ rozszerzeń. NIE rusza natomiast rzeczy specyficznych dla Zen ani lokalnych
#   preferencji — i to jest realna luka między maszynami. Ten skrypt ją domyka: kopiuje
#   wyselekcjonowane pliki profilu do iCloud (push) i z powrotem (pull). Cały profil
#   (~137 MB cache/storage/widevine) jest POMIJANY — bierzemy tylko przenośny config.
#
# Co dokładnie jedzie (luka po Firefox Sync):
#   prefs.js                    — wszystkie ustawienia about:config (compact mode, layout itd.)
#   zen-sessions.jsonlz4        — Workspaces / Spaces (sztandarowa funkcja Zen)
#   zen-themes.json + chrome/   — Zen Mods (motywy/modyfikacje) i userChrome
#   zen-keyboard-shortcuts.json — skróty klawiszowe Zen
#   zen-live-folders.jsonlz4    — live foldery
#   xulstore.json               — stan okna/UI
#   containers.json             — kontenery (multi-account containers)
#   search.json.mozlz4          — silniki wyszukiwania
#   handlers.json               — handlery protokołów/typów plików
#   permissions.sqlite          — uprawnienia per-strona
#   extension-preferences.json + extension-settings.json — ustawienia rozszerzeń
#
# Czego NIE rusza (świadomie): zakładki/hasła/historia (→ Firefox Sync), cache, storage/,
# widevine, stan logowania Sync (weave, signedInUser.json) — to per-maszyna.
#
# Magazyn (POZA gitem, w iCloud — zero churnu w repo):
#   ~/Library/Mobile Documents/com~apple~CloudDocs/zen-sync/
#
# Model: JEDEN współdzielony snapshot. push z maszyny A nadpisuje snapshot → pull na maszynie B
# go zaciąga. „Ostatni push wygrywa"; meta zapisuje kto i kiedy, `status` to pokazuje.
#
# Użycie:
#   zen-sync push     → zrzuć config z profilu do iCloud (snapshot TEJ maszyny)
#   zen-sync pull     → wgraj config z iCloud do profilu  (Zen MUSI być zamknięty)
#   zen-sync status   → stan snapshotu + czy Zen działa + porównanie dat plików
#   zen-sync diff     → które pliki różnią się między profilem a snapshotem
#   zen-sync help
set -euo pipefail

ZEN_ROOT="$HOME/Library/Application Support/zen"
ICLOUD="$HOME/Library/Mobile Documents/com~apple~CloudDocs"
SNAP="$ICLOUD/zen-sync"
META="$SNAP/meta.txt"
BACKUPS="$ZEN_ROOT/zen-sync-backups"   # backup nadpisywanych plików przy pull (poza iCloud)
KEEP_BACKUPS=5

# Pliki (płaskie) + katalogi do synchronizacji.
FILES=(
  prefs.js
  xulstore.json
  containers.json
  search.json.mozlz4
  handlers.json
  permissions.sqlite
  extension-preferences.json
  extension-settings.json
  zen-keyboard-shortcuts.json
  zen-themes.json
  zen-sessions.jsonlz4
  zen-live-folders.jsonlz4
)
DIRS=(
  chrome
)

# --- helpery ---------------------------------------------------------------

# Kolory tylko gdy stdout to terminal (przy przekierowaniu do pliku → czysty tekst).
if [ -t 1 ]; then
  c_red=$'\033[31m'; c_grn=$'\033[32m'; c_ylw=$'\033[33m'; c_dim=$'\033[2m'; c_off=$'\033[0m'
else
  c_red=""; c_grn=""; c_ylw=""; c_dim=""; c_off=""
fi

die() { printf '%szen-sync: %s%s\n' "$c_red" "$*" "$c_off" >&2; exit 1; }
info() { printf '%s\n' "$*"; }

# Aktywny profil = pole Default z installs.ini (fallback: profiles.ini). Zwraca pełną ścieżkę.
zen_profile() {
  local rel=""
  [ -f "$ZEN_ROOT/installs.ini" ] && rel="$(awk -F= '/^Default=/{print $2; exit}' "$ZEN_ROOT/installs.ini")"
  [ -z "$rel" ] && [ -f "$ZEN_ROOT/profiles.ini" ] && \
    rel="$(awk -F= '/^Default=Profiles\//{print $2; exit}' "$ZEN_ROOT/profiles.ini")"
  [ -n "$rel" ] || die "nie udało się ustalić aktywnego profilu (brak installs.ini/profiles.ini?)"
  local path="$ZEN_ROOT/$rel"
  [ -d "$path" ] || die "profil nie istnieje: $path"
  printf '%s' "$path"
}

zen_running() { pgrep -x zen >/dev/null 2>&1; }

this_host() { hostname -s 2>/dev/null || echo "unknown"; }

# --- komendy ---------------------------------------------------------------

cmd_push() {
  local profile; profile="$(zen_profile)"

  if zen_running; then
    printf '%s⚠  Zen jest URUCHOMIONY.%s Snapshot weźmie ostatnio zapisany na dysk stan\n' "$c_ylw" "$c_off"
    printf '   (prefs.js flushuje się przy zamknięciu). Dla czystego zrzutu domknij Zen.\n'
    printf '   Kontynuować mimo to? [y/N] '
    read -r ans; [ "$ans" = y ] || [ "$ans" = Y ] || die "przerwano"
  fi

  mkdir -p "$SNAP"
  local n=0
  for f in "${FILES[@]}"; do
    if [ -e "$profile/$f" ]; then
      rsync -a "$profile/$f" "$SNAP/$f"
      n=$((n+1))
    fi
  done
  for d in "${DIRS[@]}"; do
    if [ -d "$profile/$d" ]; then
      rsync -a --delete "$profile/$d/" "$SNAP/$d/"
      n=$((n+1))
    fi
  done

  {
    printf 'host=%s\n' "$(this_host)"
    printf 'date=%s\n' "$(date '+%Y-%m-%d %H:%M:%S %Z')"
    printf 'epoch=%s\n' "$(date +%s)"
    printf 'profile=%s\n' "${profile##*/}"
  } > "$META"

  info "${c_grn}✓${c_off} push: ${n} pozycji → $SNAP"
  info "${c_dim}  pull na drugiej maszynie: zamknij tam Zen i odpal: zen-sync pull${c_off}"
}

cmd_pull() {
  local profile; profile="$(zen_profile)"
  [ -d "$SNAP" ] || die "brak snapshotu w iCloud ($SNAP). Najpierw 'zen-sync push' na drugiej maszynie."
  [ -f "$META" ] || die "snapshot bez meta.txt — wygląda na niekompletny/uszkodzony"

  zen_running && die "Zen jest URUCHOMIONY — zamknij go przed 'pull' (inaczej zmiany zostaną nadpisane przy wyjściu)."

  # Skąd pochodzi snapshot — ostrzeż gdy to ta sama maszyna (pull byłby bez sensu).
  local snap_host; snap_host="$(awk -F= '/^host=/{print $2; exit}' "$META")"
  local snap_date; snap_date="$(awk -F= '/^date=/{print $2; exit}' "$META")"
  info "Snapshot: ${c_grn}${snap_host}${c_off} @ ${snap_date}"
  if [ "$snap_host" = "$(this_host)" ]; then
    printf '%s⚠  Snapshot pochodzi z TEJ maszyny (%s).%s Pull nadpisze lokalny config jego kopią.\n' \
      "$c_ylw" "$snap_host" "$c_off"
  fi
  printf 'Wgrać snapshot do profilu „%s"? [y/N] ' "${profile##*/}"
  read -r ans; [ "$ans" = y ] || [ "$ans" = Y ] || die "przerwano"

  # Backup nadpisywanych plików (odwracalność).
  local stamp bak; stamp="$(date +%Y%m%d-%H%M%S)"; bak="$BACKUPS/$stamp"
  mkdir -p "$bak"
  local n=0
  for f in "${FILES[@]}"; do
    if [ -e "$SNAP/$f" ]; then
      [ -e "$profile/$f" ] && rsync -a "$profile/$f" "$bak/$f"
      rsync -a "$SNAP/$f" "$profile/$f"
      # sqlite: usuń osierocone -wal/-shm, by nie kłóciły się ze świeżą bazą.
      case "$f" in
        *.sqlite) rm -f "$profile/$f-wal" "$profile/$f-shm" ;;
      esac
      n=$((n+1))
    fi
  done
  for d in "${DIRS[@]}"; do
    if [ -d "$SNAP/$d" ]; then
      [ -d "$profile/$d" ] && rsync -a "$profile/$d/" "$bak/$d/"
      rsync -a --delete "$SNAP/$d/" "$profile/$d/"
      n=$((n+1))
    fi
  done

  # Rotacja backupów — trzymaj ostatnie KEEP_BACKUPS.
  if [ -d "$BACKUPS" ]; then
    local old
    old="$(ls -1 "$BACKUPS" 2>/dev/null | sort | head -n -"$KEEP_BACKUPS" || true)"
    [ -n "$old" ] && while IFS= read -r dir; do rm -rf "$BACKUPS/$dir"; done <<< "$old"
  fi

  info "${c_grn}✓${c_off} pull: ${n} pozycji wgranych. Backup poprzednich: ${c_dim}$bak${c_off}"
  info "  Uruchom teraz Zen — Workspaces/mody/ustawienia powinny być zsynchronizowane."
}

cmd_status() {
  local profile; profile="$(zen_profile)"
  info "Profil:    ${profile##*/}"
  info "Maszyna:   $(this_host)"
  if zen_running; then info "Zen:       ${c_ylw}uruchomiony${c_off} (zamknij przed pull)"
  else info "Zen:       ${c_dim}zamknięty${c_off}"; fi

  if [ -f "$META" ]; then
    info "Snapshot:  ${c_grn}$(awk -F= '/^host=/{print $2}' "$META")${c_off} @ $(awk -F= '/^date=/{print $2}' "$META")"
  else
    info "Snapshot:  ${c_dim}brak (jeszcze nie było push)${c_off}"
    return 0
  fi

  info ""
  info "Porównanie (profil vs snapshot):"
  for f in "${FILES[@]}"; do
    local p="$profile/$f" s="$SNAP/$f" tag
    if [ ! -e "$p" ] && [ ! -e "$s" ]; then continue
    elif [ ! -e "$s" ]; then tag="${c_ylw}tylko lokalnie${c_off}"
    elif [ ! -e "$p" ]; then tag="${c_ylw}tylko w snapshocie${c_off}"
    elif cmp -s "$p" "$s"; then tag="${c_dim}=${c_off}"
    elif [ "$p" -nt "$s" ]; then tag="${c_grn}lokalny nowszy${c_off} → rozważ push"
    else tag="${c_ylw}snapshot nowszy${c_off} → rozważ pull"
    fi
    printf '  %-32s %b\n' "$f" "$tag"
  done
}

cmd_diff() {
  local profile; profile="$(zen_profile)"
  [ -f "$META" ] || die "brak snapshotu"
  local any=0
  for f in "${FILES[@]}"; do
    local p="$profile/$f" s="$SNAP/$f"
    [ -e "$p" ] && [ -e "$s" ] || continue
    if ! cmp -s "$p" "$s"; then printf 'różni się: %s\n' "$f"; any=1; fi
  done
  [ "$any" = 0 ] && info "${c_grn}✓${c_off} brak różnic między profilem a snapshotem"
}

case "${1:-status}" in
  push)   cmd_push ;;
  pull)   cmd_pull ;;
  status) cmd_status ;;
  diff)   cmd_diff ;;
  help|-h|--help)
    sed -n '2,40p' "$0" | sed 's/^# \{0,1\}//' ;;
  *) die "nieznana komenda: $1 (użycie: zen-sync [push|pull|status|diff|help])" ;;
esac
