# Czcionka
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 16

# Wygląd okna i przezroczystość
background-opacity = 0.99
background-blur = 20

# Padding wokół treści
window-padding-x = 12
window-padding-y = 10
window-padding-balance = true
window-padding-color = extend

# Motyw kolorystyczny — default + opcjonalny lokalny override (per-urządzenie, NIE w repo).
# BEZ ruszania trybu jasny/ciemny macOS. Plik ~/.config/ghostty-theme.local leży POZA
# symlinkowanym katalogiem stow, więc nie trafia do gita; gdy istnieje, nadpisuje theme.
# Zapisuje go skrypt `theme` (~/.local/bin/theme), który ręcznie przełącza terminal + nvim.
# Brak pliku (np. świeża maszyna) → zostaje default poniżej. '?' = include opcjonalny.
theme = Catppuccin Mocha
config-file = ?~/.config/ghostty-theme.local

shell-integration-features = no-cursor
keybind = shift+enter=text:\x1b\r
window-save-state = never
window-decoration = auto
macos-option-as-alt = true
